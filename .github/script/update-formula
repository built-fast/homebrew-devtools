#!/usr/bin/env bash

set -e

: "${VERSION:?Must specify version}"
: "${FORMULA:?Must specify formula}"

FORMULA_FILE="Formula/$FORMULA.rb"

# Check if formula file exists
if [[ ! -f "$FORMULA_FILE" ]]; then
  echo "Error: Formula file $FORMULA_FILE not found"
  exit 1
fi

sed_inplace() {
  if [[ "$OSTYPE" == "darwin"* ]]; then
    sed -i '' "$@"
  else
    sed -i "$@"
  fi
}

# Update version
sed_inplace "s/version \".*\"/version \"${VERSION#v}\"/" "$FORMULA_FILE"

# Check if this is a multi-platform formula (has platform-specific URLs)
if grep -q "aarch64-apple-darwin" "$FORMULA_FILE"; then
  # Multi-platform formula (e.g., vector)
  # Extract the repo name from the homepage or URL
  REPO=$(grep -m1 'homepage' "$FORMULA_FILE" | sed 's/.*github.com\/built-fast\/\([^"]*\).*/\1/')

  PLATFORMS=(
    "aarch64-apple-darwin"
    "x86_64-apple-darwin"
    "aarch64-unknown-linux-gnu"
    "x86_64-unknown-linux-gnu"
  )

  for PLATFORM in "${PLATFORMS[@]}"; do
    URL="https://github.com/built-fast/$REPO/releases/download/$VERSION/$FORMULA-$PLATFORM.tar.gz"
    echo "Fetching $URL"
    SHASUM=$(curl -sL "$URL" | shasum -a 256 | awk '{ print $1 }')
    echo "  sha256: $SHASUM"

    # Replace the sha256 on the line after the URL containing this platform
    sed_inplace "/$PLATFORM/{n;s/sha256 \".*\"/sha256 \"$SHASUM\"/;}" "$FORMULA_FILE"
  done
else
  # Single tarball formula (e.g., lcars)
  SHASUM=$(
    curl -sL "https://github.com/built-fast/$FORMULA/archive/$VERSION.tar.gz" |
      shasum -a 256 |
      awk '{ print $1 }'
  )
  sed_inplace "s/sha256   \".*\"/sha256   \"$SHASUM\"/" "$FORMULA_FILE"
fi
